#!/bin/bash

# edit.sh
# Calls butterfish prompt to rewrite a selected code block based on a prompt,
# using the full file as additional context.
# Arguments:
#   $1: filetype, e.g. go, py, js
#   $2: filepath, the path to the file to edit
#   $3: cursor/range, the selected line or line block to replace
#   $4: prompt, the user's requested edits
# Output: Streams replacement code for the selected range to stdout
# Example: ./edit.sh go foobar.go 1 "rename this function"
# butterfish.nvim command: :BFEdit

# This is a script for butterfish.nvim, it accepts arguments from the plugin
# constructs language model prompts, and calls Butterfish to generate a response
# using the OpenAI API. You can modify this script to change the prompt or
# swap in a different language model.

# Source common.sh from the same directory as this script
source "$(dirname "${BASH_SOURCE[0]}")/common.sh"

parse_arguments "$@"

focus_note=""
if [ -n "$fileblock" ]; then
  focus_note="

Rewrite this selected code block:
\"\"\"
$fileblock
\"\"\""
fi

request_prompt="$prompt$focus_note"

sysmsg="You are editing a selected block in an existing $filetype source file. Return only the replacement code for the selected block. Do not include explanations, markdown fences, or any extra text."

fullprompt="Apply the requested edits to the selected code block. You can use the full file as context.

Edit request:
$request_prompt

Full file context:
\"\"\"
$filecontents
\"\"\""

lm_command "$sysmsg" "$fullprompt" "$lm_model" "$lm_basepath"
